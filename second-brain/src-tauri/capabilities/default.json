{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for the Second Brain desktop app",
  "windows": ["main", "capture-overlay"],
  "permissions": [
    "core:default",
    "global-shortcut:allow-register",
    "global-shortcut:allow-unregister",
    "shell:allow-execute",
    "shell:allow-open",
    "notification:default",
    "notification:allow-notify",
    "dialog:default",
    "fs:default",
    "fs:allow-read",
    "fs:allow-write"
  ]
}
