# Second Brain — environment configuration
#
# Copy this file to `.env` and edit the DATABASE_URL for your machine.
#
# IMPORTANT: Prisma resolves relative paths from the prisma/ directory (where
# schema.prisma lives), NOT from the project root. This is confusing, so we
# recommend using an ABSOLUTE path. Pick the line for your OS below.
#
# ── Linux / macOS (sandbox) ──────────────────────────────────
DATABASE_URL="file:/home/z/whisper_flow_clone/second-brain/db/second-brain.db"
#
# ── Windows ──────────────────────────────────────────────────
# Use forward slashes or double backslashes in the path. The path below
# assumes you cloned the repo to C:\Users\Parth\Desktop\whisper
# DATABASE_URL="file:C:/Users/Parth/Desktop/whisper/second-brain/db/second-brain.db"
#
# ── Relative path fallback (works if you always run `bun run dev` from the
#    second-brain/ directory; Prisma resolves from prisma/ so ../db/ lands
#    in second-brain/db/) ──────────────────────────────────────
# DATABASE_URL="file:../db/second-brain.db"
