// Second Brain Prisma schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Note {
  id          String   @id @default(cuid())
  title       String
  body        String
  rawTranscript String? // verbatim STT output before LLM polish
  type        String   @default("journal") // idea | task | reference | question | journal | dictation
  tags        String   @default("") // comma-separated for simplicity
  vaultPath   String?  // relative path in ~/SecondBrain/
  source      String   @default("voice") // voice | text | dictation | import
  appContext  String?  // what app was focused when captured
  confidence  Float    @default(0.0) // LLM classification confidence
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tasks       Task[]
  links       Link[]   @relation("Outgoing")
  backlinks   Link[]   @relation("Incoming")

  @@index([type])
  @@index([createdAt])
}

model Task {
  id        Int      @id @default(autoincrement())
  noteId    String
  note      Note     @relation(fields: [noteId], references: [id], onDelete: Cascade)
  text      String
  done      Boolean  @default(false)
  due       DateTime?
  createdAt DateTime @default(now())

  @@index([done, due])
  @@index([noteId])
}

model Link {
  id        Int     @id @default(autoincrement())
  sourceId  String
  source    Note    @relation("Outgoing", fields: [sourceId], references: [id], onDelete: Cascade)
  targetId  String?
  target    Note?   @relation("Incoming", fields: [targetId], references: [id], onDelete: Cascade)
  similarity Float  @default(0.0) // cosine similarity for auto-links
  type      String  @default("semantic") // semantic | wikilink | tag

  @@index([sourceId])
  @@index([targetId])
}
