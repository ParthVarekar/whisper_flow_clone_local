// Second Brain Prisma schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Note {
  id          String   @id @default(cuid())
  title       String
  body        String
  rawTranscript String? // verbatim STT output before LLM polish
  type        String   @default("journal") // idea | task | reference | question | journal | dictation | uncategorized
  tags        String   @default("") // comma-separated (controlled vocab + free-form)
  vaultPath   String?  // relative path in ~/SecondBrain/ vault
  source      String   @default("voice") // voice | text | dictation | import
  appContext  String?  // what app was focused when captured
  confidence  Float    @default(0.0) // LLM classification confidence (0.0-1.0)
  // Review loop (Phase B): an inbox note becomes "processed" after the user
  // reviews it in the daily review screen. Archived notes are hidden from the
  // timeline but kept for search.
  status      String   @default("inbox") // inbox | processed | archived
  reviewedAt  DateTime?
  // Semantic search (Step 3): 384-dim all-MiniLM-L6-v2 embedding stored as
  // Float32Array → Buffer. Null when embeddings are unavailable (model not
  // downloaded yet) or not yet computed.
  embedding   Bytes?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tasks       Task[]
  links       Link[]   @relation("Outgoing")
  backlinks   Link[]   @relation("Incoming")

  @@index([type])
  @@index([status])
  @@index([createdAt])
}

model Task {
  id        Int      @id @default(autoincrement())
  noteId    String
  note      Note     @relation(fields: [noteId], references: [id], onDelete: Cascade)
  text      String
  done      Boolean  @default(false)
  due       DateTime?
  createdAt DateTime @default(now())

  @@index([done, due])
  @@index([noteId])
}

model Link {
  id        Int     @id @default(autoincrement())
  sourceId  String
  source    Note    @relation("Outgoing", fields: [sourceId], references: [id], onDelete: Cascade)
  targetId  String?
  target    Note?   @relation("Incoming", fields: [targetId], references: [id], onDelete: Cascade)
  similarity Float  @default(0.0) // 0-1; cosine for semantic, overlap ratio for keyword
  type      String  @default("keyword") // keyword | semantic | wikilink | tag

  @@index([sourceId])
  @@index([targetId])
  @@index([type])
}
